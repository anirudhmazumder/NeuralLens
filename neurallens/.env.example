# NeuralLens web app environment template

# Set true to use live Anthropic calls in backend/agent.py.
CLAUDE_LIVE=false

# Required only when CLAUDE_LIVE=true.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Set true to score with your TRIBE endpoint in backend/scorer.py.
TRIBE_LIVE=false

# TRIBE /encode endpoint URL.
TRIBE_ENDPOINT=http://localhost:9090/encode

# Optional bearer token for TRIBE endpoints requiring authorization.
TRIBE_TOKEN=
