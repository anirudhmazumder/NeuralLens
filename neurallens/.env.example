# NeuralLens web app environment template

# Set true to use live OpenAI calls in backend/agent.py.
OPENAI_LIVE=false

# Required only when OPENAI_LIVE=true.
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use for agent edits.
OPENAI_MODEL=gpt-4.1-nano

# Set true to score with your TRIBE endpoint in backend/scorer.py.
TRIBE_LIVE=false

# TRIBE /encode endpoint URL.
TRIBE_ENDPOINT=http://localhost:9090/encode

# Timeout in seconds for live TRIBE calls.
TRIBE_TIMEOUT_SECONDS=90

# Optional bearer token for TRIBE endpoints requiring authorization.
TRIBE_TOKEN=

# Set true to use DeepGaze for live gaze prediction.
GAZE_LIVE=false

# Path to centerbias .npy file (defaults to centerbias_mit1003.npy in repo root).
CENTERBIAS_PATH=

# Device for DeepGaze model inference (cpu or cuda).
GAZE_DEVICE=cpu
